generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

// Enums for Roles
enum Role {
  CUSTOMER
  VENDOR
  RIDER
  ADMIN
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  PICKED_UP
  DELIVERED
  CANCELLED
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  phone     String   @unique
  password  String
  name      String
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  hostel      String?
  roomNumber  String?
  profileImageUrl String?
  
  // Relations

  orders        Order[] @relation("CustomerOrders")
  vendorProfile VendorProfile?
  riderProfile  RiderProfile?
}

model VendorProfile {
  id          Int     @id @default(autoincrement())
  shopName    String
  shopType    String
  openingTime String // e.g., "08:00 AM"
  closingTime String
  description String?
  isOpen      Boolean @default(true)
  orders      Order[]
  
  userId      Int     @unique
  user        User    @relation(fields: [userId], references: [id])
  // products    Product[].  products will be added later when we implement the Product model
}

model RiderProfile {
  id          Int     @id @default(autoincrement())
  vehicleType String  // Bike, Car, Bicycle....
  vehicleNo   String? // Vehicle Registration Number, could be kept optional keeping in mind that riders might have Bicycle too.
  isAvailable Boolean @default(true)
  deliveries  Order[]
  
  userId      Int     @unique
  user        User    @relation(fields: [userId], references: [id])
}

model Order {
  id          Int         @id @default(autoincrement())
  customerId  Int
  vendorId    Int
  riderId     Int?
  status      OrderStatus @default(PENDING)
  totalAmount Float
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  customer User @relation("CustomerOrders", fields: [customerId], references: [id])
  vendor   VendorProfile @relation(fields: [vendorId], references: [id])
  rider    RiderProfile?  @relation(fields: [riderId], references: [id])

  items OrderItem[]

  @@index([customerId])
}

model OrderItem {
  id        Int @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int @default(1)
  price     Float

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}