{
  "name": "iitkart-backend",
  "version": "1.0.0",
  "description": "Backend for IITKart",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "jest --coverage",
    "test:with-dev": "bash scripts/test-with-dev.sh",
    "test:integration": "jest tests/integration-all-issues.test.ts --coverage",
    "test:integration:with-dev": "bash scripts/test-with-dev.sh integration",
    "test:queue": "jest tests/queue-persistence.test.ts --coverage",
    "test:payment": "jest tests/payment-edge-cases.test.ts --coverage",
    "test:concurrent": "jest tests/concurrent-resilience.test.ts --coverage",
    "test:delivery": "jest tests/delivery-rider.test.ts --coverage",
    "test:stress": "ts-node tests/stress-test.ts",
    "test:stress:with-dev": "bash scripts/test-with-dev.sh stress",
    "test:frontend": "jest tests/ui-issues.test.ts --coverage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageReporters=lcov --coverageDirectory=coverage",
    "test:all-with-dev": "bash scripts/test-with-dev.sh"
  },
  "dependencies": {
    "@prisma/client": "^5.x",
    "axios": "^1.x",
    "bcryptjs": "^2.x",
    "compression": "^1.x",
    "cors": "^2.x",
    "dotenv": "^16.x",
    "express": "^4.x",
    "helmet": "^7.x",
    "json2csv": "^5.0.7",
    "jsonwebtoken": "^9.x",
    "morgan": "^1.x",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "razorpay": "^2.x",
    "winston": "^3.x",
    "zod": "^3.x"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.x",
    "@types/compression": "^1.x",
    "@types/cors": "^2.x",
    "@types/express": "^4.x",
    "@types/jest": "^29.x",
    "@types/json2csv": "^5.0.7",
    "@types/jsonwebtoken": "^9.x",
    "@types/morgan": "^1.x",
    "@types/multer": "^1.x",
    "@types/node": "^20.x",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.x",
    "jest": "^29.x",
    "prisma": "^5.x",
    "supertest": "^6.x",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.x",
    "ts-node-dev": "^2.x",
    "typescript": "^5.x"
  }
}
